VITE_BASE=/

# 预览环境直接走云端 API
VITE_GLOB_API_URL=https://cloud.battcn.com/api

# 是否开启压缩
VITE_COMPRESS=gzip

# 是否开启 PWA
VITE_PWA=false

# 线上预览统一使用 hash 路由，避免刷新 404
VITE_ROUTER_HISTORY=hash

# 是否注入全局 loading
VITE_INJECT_APP_LOADING=true

# 预览站关闭 Gitee 演示拦截
VITE_GITEE_INTERCEPT=false

# 地图服务配置
VITE_MAP_TYPE=mock
